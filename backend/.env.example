# Server
PORT=3001
FRONTEND_URL=http://localhost:3000

# MongoDB — local via Docker (mongodb-atlas-local supports vector search)
MONGODB_URI=mongodb://localhost:27017/llm_chatbot?directConnection=true
# Production (MongoDB Atlas) alternative:
# MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/llm_chatbot?retryWrites=true&w=majority

# Claude (generation) — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Embeddings provider (Claude does NOT embed). Voyage by default: https://voyageai.com
EMBEDDINGS_API_KEY=pa-...
EMBEDDINGS_MODEL=voyage-3
